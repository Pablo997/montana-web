# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key is NOT required by the current codebase. RLS policies
# and SECURITY DEFINER RPCs handle all privileged operations. Only add
# SUPABASE_SERVICE_ROLE_KEY here if you introduce a server-side flow
# that explicitly needs to bypass RLS. If you add it, mark it as a
# secret in your deployment provider and never prefix it with NEXT_PUBLIC_.

# MapTiler (https://cloud.maptiler.com/account/keys/)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Voting thresholds (optional overrides; defaults live in DB)
NEXT_PUBLIC_VALIDATION_THRESHOLD=5
NEXT_PUBLIC_DISMISSAL_THRESHOLD=5

# ---------------------------------------------------------------------------
# Sentry (error monitoring)
# ---------------------------------------------------------------------------
# All three are optional: if NEXT_PUBLIC_SENTRY_DSN is missing the SDK
# becomes a no-op and the app boots normally. Set them in Vercel's
# environment variables UI, not in a committed .env file.
#
# DSN is safe to expose client-side; it's the ingest endpoint, not a
# secret. AUTH_TOKEN is a build-time secret used only to upload source
# maps to Sentry during `next build` — mark it as a secret in Vercel.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=montana-web
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Web Push (browser notifications for nearby incidents)
# ---------------------------------------------------------------------------
# VAPID keys identify this server to push services (FCM, Mozilla, Apple) so
# they accept our signed push requests. Generate a fresh pair with:
#
#   npm run vapid:generate
#
# Only the PUBLIC key goes in the Next.js bundle (it's attached to each
# PushSubscription by design). The PRIVATE key lives exclusively in the
# Supabase Edge Function that actually sends the pushes — never commit it
# and never expose it via NEXT_PUBLIC_*.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
