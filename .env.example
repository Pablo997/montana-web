# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MapTiler (https://cloud.maptiler.com/account/keys/)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Voting thresholds (optional overrides; defaults live in DB)
NEXT_PUBLIC_VALIDATION_THRESHOLD=5
NEXT_PUBLIC_DISMISSAL_THRESHOLD=5
